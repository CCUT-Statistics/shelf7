i.icon-digest-2 {  text-shadow: 0 0 3px #FFF177; }
i.icon-digest-3 {  text-shadow: 0 0 3px #FF8D8D; } */
.icon-digest-1:before {color: #5BC0DE;} /* "\f0a5" */
.icon-digest-2:before {color: #ECA541;}
.icon-digest-3:before {color: #D53D38;}
