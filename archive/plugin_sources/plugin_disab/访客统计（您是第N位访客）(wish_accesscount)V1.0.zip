<div class="container">
	<form class="font_search" method="get">
	<div class="input-group">
		<input type="text" class="form-control" name="fontname" onkeyup="if(value.length>20) value=value.slice(0,20)" id="fontname" value="" placeholder="输入资源、教程的关键词">
		<div class="input-group-append">
			<button id="search_button" class="btn btn-success" onclick='search_check();search_start_down()' > <i class="icon-search"></i> <span id="search_button_title">一键搜索</span></button>
		</div>
	</div>
	</form>
